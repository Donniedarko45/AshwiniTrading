# ==============================================================================
# ASHWINI TRADING ACADEMY — PRODUCTION ENVIRONMENT TEMPLATE
# ==============================================================================
# Copy this to .env.production and fill in real values.
# This file is used by Docker Compose at runtime.
# NEVER commit .env.production to version control.
# ==============================================================================

# 1. Express Backend Server
PORT=5000
NODE_ENV=production

# 2. Application Base URL (your production domain)
APP_URL=https://ashwinitradingacademy.com

# 3. PostgreSQL (Neon.tech) — Connection string with SSL
# Get this from your Neon.tech dashboard → Connection Details → Connection String
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/ashwini_trading?sslmode=require"

# 4. Cashfree Payment Gateway — Production Credentials
# Get these from: https://merchant.cashfree.com/merchant/pg
CF_CLIENT_ID="your_production_client_id"
CF_CLIENT_SECRET="your_production_client_secret"

# 5. Cashfree Environment (must be 'production' for live payments)
CF_ENVIRONMENT="production"

# 6. Webhook Verification Secret
CF_WEBHOOK_SECRET="your_webhook_secret"

# 7. Gemini AI Integration (optional)
GEMINI_API_KEY="your_gemini_api_key"

# 8. SMTP Email settings (for forwarding lead form enquiries)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false" # set "true" for port 465, "false" for 587/25
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM="Ashwini Trading Academy Leads <no-reply@ashwinitradingacademy.com>"
