# ==============================================================================
# ASHWINI TRADING ACADEMY - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# 1. Express Backend Server Configuration
# The port where the backend API server will run (default: 5000)
PORT=5000

# 2. Application Base URL
# The URL where your frontend is hosted. This is used by Cashfree to redirect 
# the user after payment and to send webhook notifications.
# Local development: http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000

# 3. PostgreSQL Database Configuration
# Prisma connection URL for your PostgreSQL database instance.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ashwini_trading?schema=public"

# 4. Cashfree Payment Gateway Credentials
# Retrieve these credentials from your Cashfree Merchant Dashboard:
# Sandbox: https://merchant.cashfree.com/merchant/pg
# Production: Contact Cashfree support / activate account to get production keys
CF_CLIENT_ID="YOUR_CASHFREE_CLIENT_ID_OR_APP_ID"
CF_CLIENT_SECRET="YOUR_CASHFREE_CLIENT_SECRET_OR_SECRET_KEY"

# 5. Cashfree Environment Settings
# Set to 'sandbox' for testing and 'production' for live payments
CF_ENVIRONMENT="sandbox"

# 6. Webhook Verification Secret
# Used to secure webhook endpoints. In Cashfree, this is typically your Client Secret.
CF_WEBHOOK_SECRET="YOUR_CASHFREE_CLIENT_SECRET_OR_WEBHOOK_KEY"

# 7. Gemini AI Integration (Existing)
# Required if using AI Studio features
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
